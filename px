local player = game.Players.LocalPlayer
local userInputService = game:GetService("UserInputService")
local runService = game:GetService("RunService")

local surfKey = Enum.KeyCode.E -- Taste zum Surfen
local isSurfing = false
local surfConnection = nil

-- Warte auf Charakter
local function getCharacter()
    return player.Character or player.CharacterAdded:Wait()
end

local character = getCharacter()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- Raycast für Wandnormalen (modern)
local function getWallNormal()
    local origin = rootPart.Position
    local direction = rootPart.CFrame.LookVector * 3
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {character}
    
    local result = workspace:Raycast(origin, direction, raycastParams)
    if result and result.Normal then
        return result.Normal
    end
    return nil
end

local function onHeartbeat(dt)
    if not isSurfing then return end
    
    local wallNormal = getWallNormal()
    if not wallNormal then
        isSurfing = false
        humanoid.WalkSpeed = 16
        return
    end
    
    -- Bewegungseingabe (WASD)
    local moveDir = Vector3.new()
    if userInputService:IsKeyDown(Enum.KeyCode.W) then
        moveDir += rootPart.CFrame.LookVector
    end
    if userInputService:IsKeyDown(Enum.KeyCode.S) then
        moveDir -= rootPart.CFrame.LookVector
    end
    if userInputService:IsKeyDown(Enum.KeyCode.A) then
        moveDir -= rootPart.CFrame.RightVector
    end
    if userInputService:IsKeyDown(Enum.KeyCode.D) then
        moveDir += rootPart.CFrame.RightVector
    end
    
    -- Bewegung entlang der Wandoberfläche
    local surfDir = moveDir - wallNormal * moveDir:Dot(wallNormal)
    if surfDir.Magnitude > 0.1 then
        surfDir = surfDir.Unit * 50
        rootPart.Velocity = Vector3.new(surfDir.X, rootPart.Velocity.Y, surfDir.Z)
    end
    
    -- An der Wand kleben (Gravitationskomponente entlang der Normalen ausgleichen)
    local gravity = Vector3.new(0, -196.2, 0)
    local wallForce = wallNormal * -gravity:Dot(wallNormal)
    rootPart.Velocity += wallForce * dt
    
    humanoid.WalkSpeed = 0
end

-- Tastendruck startet Surfen
userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == surfKey and not isSurfing then
        local wallNormal = getWallNormal()
        if wallNormal then
            isSurfing = true
            surfConnection = runService.Heartbeat:Connect(onHeartbeat)
        end
    end
end)

-- Loslassen beendet Surfen
userInputService.InputEnded:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == surfKey and isSurfing then
        isSurfing = false
        if surfConnection then
            surfConnection:Disconnect()
            surfConnection = nil
        end
        humanoid.WalkSpeed = 16
    end
end)
